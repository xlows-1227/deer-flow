# 所有脚本都需要
export DEER_FLOW_IMAGE_TAG="v0.3.0"

# 镜像命名；默认值如下，可按实际仓库覆盖
export IMAGE_REGISTRY="ghcr.io/xlows-1227"
# export DEER_FLOW_FRONTEND_IMAGE="your-registry/deer-flow-frontend:${DEER_FLOW_IMAGE_TAG}"
# export DEER_FLOW_BACKEND_IMAGE="your-registry/deer-flow-backend:${DEER_FLOW_IMAGE_TAG}"

# 01-test-package-upload.sh：测试机和 FileBrowser 在同一台机器，直接复制文件
export FILEBROWSER_DATA_DIR="/opt/file/data/deer-flow"
# export FILEBROWSER_FILE_MODE="0644"
# export FILEBROWSER_DATA_OWNER="filebrowser:filebrowser"

# 仅本地 02-local-relay.sh 使用
export TEST_FILEBROWSER_URL="http://test-filebrowser.example:8001"
export TEST_FILEBROWSER_USERNAME="admin"
export TEST_FILEBROWSER_PASSWORD="请替换"
export TEST_FILEBROWSER_REMOTE_DIR="deer-flow"

# 本地 02 脚本通过 expect 登录测试服务器并执行远端 01 脚本
export RUN_TEST_REMOTE_PACKAGE=1
export BASTION_HOST="61.155.145.200"
export BASTION_PORT="52222"
export BASTION_USER="请替换"
export BASTION_PASS="请替换"
# 兼容只提供 ssh-rsa 主机密钥的旧堡垒机
export BASTION_ENABLE_LEGACY_SSH_RSA=1
export TEST_TARGET_IP="10.218.221.161"
export TEST_REMOTE_SCRIPT_PATH="/opt/deer-flow/scripts/filebrowser-image-transfer/01-test-package-upload.sh"
# sudo 密码默认复用 BASTION_PASS
# export TEST_SUDO_PASSWORD="请替换"
# export TEST_REMOTE_TIMEOUT=7200
# export TEST_REMOTE_BUILD_IMAGES=0
# 远端 01 默认并发执行两次 docker save | gzip
# export TEST_REMOTE_PARALLEL_IMAGE_PACKAGING=1
# export TEST_REMOTE_WORK_DIR="/tmp/deer-flow-image-transfer/${DEER_FLOW_IMAGE_TAG}"
# 远端 01 复制到测试机 FileBrowser 的本地数据目录
# export TEST_REMOTE_FILEBROWSER_DATA_DIR="/opt/file/data/deer-flow"
# 02 调用远端 01 时默认重新打包；设为 upload 可直接复制测试机已有文件
# export TEST_REMOTE_EXISTING_PACKAGE_ACTION="repackage"

export PROD_FILEBROWSER_URL="http://prod-filebrowser.example:8001"
export PROD_FILEBROWSER_USERNAME="admin"
export PROD_FILEBROWSER_PASSWORD="请替换"
export PROD_FILEBROWSER_REMOTE_DIR="deer-flow"

# 03-prod-download-load.sh：生产服务器通过 SCP 拉取文件
export SCP_HOST="172.20.62.36"
export SCP_USER="root"
export SCP_PORT="22"
export SCP_REMOTE_DIR="/opt/tools/file_browser/deer-flow"
# 默认下载到执行 03 时的当前目录
# export TRANSFER_WORK_DIR="/tmp/deer-flow-images/${DEER_FLOW_IMAGE_TAG}"
# export SCP_IDENTITY_FILE="/root/.ssh/id_rsa"
# export SCP_ENABLE_LEGACY_SSH_RSA=1
# export SCP_USE_LEGACY_PROTOCOL=1

# 03 交互确认；设为 1/0 可用于无人值守
# export LOAD_IMAGES_ACTION=ask
# export DEPLOY_AFTER_LOAD=ask
# export DEER_FLOW_DEPLOY_DIR="/opt/deer-flow"

# 自签名 HTTPS 可设置为 1；优先使用 *_CA_CERT 指定 CA 文件
# export TEST_FILEBROWSER_INSECURE=1
# export PROD_FILEBROWSER_INSECURE=1

# 登录连接重置时自动重试；HTTP 401/403 等业务响应不会重试
# export FILEBROWSER_LOGIN_RETRIES=3
# export FILEBROWSER_RETRY_DELAY=2
# export FILEBROWSER_LOGIN_TIMEOUT=60

# 测试机默认只打包已有镜像；设置为 1 时从当前仓库构建镜像
# export BUILD_IMAGES=1
# export DOCKER_BUILD_PLATFORM=linux/amd64
# 01 是否并发导出、压缩前后端镜像
# export PARALLEL_IMAGE_PACKAGING=1
# 01 检测到完整打包文件时：ask、upload、repackage 或 abort
# export EXISTING_PACKAGE_ACTION=ask

# 可选
# export TRANSFER_WORK_DIR="/tmp/deer-flow-image-transfer/${DEER_FLOW_IMAGE_TAG}"
# 本地文件已存在时：ask 交互确认（默认），1 强制重拉，0 直接复用
# export REDOWNLOAD_EXISTING=ask
# 02 默认并发下载、上传前端和后端镜像；设为 0 恢复串行
# export PARALLEL_TRANSFERS=1
# export KEEP_ARCHIVES=1
# export CLEAN_LOCAL_AFTER_UPLOAD=1
